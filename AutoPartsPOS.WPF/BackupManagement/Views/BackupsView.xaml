<UserControl x:Class="AutoPartsPOS.WPF.Backups.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <Grid MaxWidth="1180">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="النسخ الاحتياطية" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="احفظ بيانات المتجر واستعدها بأمان عند الحاجة." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" FlowDirection="LeftToRight">
                <Button Margin="8,0,0,0"
                        Command="{Binding OpenBackupsFolderCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        ToolTip="فتح مجلد النسخ">
                    <materialDesign:PackIcon Kind="FolderOpenOutline" />
                </Button>
                <Button Command="{Binding CreateBackupCommand}" Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Margin="0,0,8,0" Kind="DatabasePlusOutline" />
                        <TextBlock Text="إنشاء نسخة الآن" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,20,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" Background="#ECFDF5" CornerRadius="10">
                <StackPanel>
                    <materialDesign:PackIcon Width="28" Height="28" Foreground="#047857" Kind="CalendarCheckOutline" />
                    <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="SemiBold" Text="نسخة يومية تلقائية" />
                    <TextBlock Margin="0,5,0,0" Foreground="#526D64" Text="تُنشأ مرة واحدة يوميًا عند تشغيل البرنامج." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="18" Background="#EFF6FF" CornerRadius="10">
                <StackPanel>
                    <materialDesign:PackIcon Width="28" Height="28" Foreground="#2563EB" Kind="ShieldCheckOutline" />
                    <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="SemiBold" Text="استعادة محمية" />
                    <TextBlock Margin="0,5,0,0" Foreground="#52677F" Text="يتم فحص الملف وحفظ نسخة أمان قبل الاستعادة." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Padding="18" Background="#FFF7ED" CornerRadius="10">
                <StackPanel>
                    <materialDesign:PackIcon Width="28" Height="28" Foreground="#C2410C" Kind="ImportExport" />
                    <TextBlock Margin="0,12,0,0" FontSize="15" FontWeight="SemiBold" Text="استيراد وتصدير" />
                    <TextBlock Margin="0,5,0,0" Foreground="#755B4D" Text="انقل نسخة قاعدة البيانات إلى جهاز أو مكان آمن." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource ToolbarCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Command="{Binding ImportCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,7,0" Kind="DatabaseImportOutline" />
                            <TextBlock Text="استيراد" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,0,8,0" Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,7,0" Kind="DatabaseExportOutline" />
                            <TextBlock Text="تصدير المحددة" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RestoreCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,7,0" Kind="DatabaseRefreshOutline" />
                            <TextBlock Text="استعادة المحددة" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Command="{Binding RefreshCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="تحديث القائمة">
                        <materialDesign:PackIcon Kind="Refresh" />
                    </Button>
                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,7,0" Kind="DeleteOutline" />
                            <TextBlock Text="حذف" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <DataGrid AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Backups}"
                          SelectedItem="{Binding SelectedBackup}"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="62">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="38" Height="38" Background="{DynamicResource AppPrimarySoftBrush}" CornerRadius="9">
                                        <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource AppPrimaryBrush}" Kind="DatabaseOutline" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Width="*" MinWidth="280" Header="اسم النسخة" Binding="{Binding FileName}" />
                        <DataGridTextColumn Width="150" Header="النوع" Binding="{Binding TypeDisplay}" />
                        <DataGridTextColumn Width="210" Header="تاريخ الإنشاء" Binding="{Binding CreatedAtDisplay}" />
                        <DataGridTextColumn Width="120" Header="الحجم" Binding="{Binding SizeDisplay}" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Backups.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Width="52" Height="52" HorizontalAlignment="Center"
                                             Foreground="{DynamicResource AppMutedTextBrush}" Kind="DatabaseOffOutline" />
                    <TextBlock Margin="0,14,0,0" FontSize="16" FontWeight="SemiBold" Text="لا توجد نسخ احتياطية" />
                    <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="أنشئ أول نسخة لحماية بيانات المتجر." />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Border Padding="14,10" Background="#ECFDF3" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="#166534" Text="{Binding SuccessMessage}" TextWrapping="Wrap" />
            </Border>
            <Border Padding="14,10" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="#991B1B" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
            </Border>
            <ProgressBar Height="3" VerticalAlignment="Bottom" IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
    </Grid>
</UserControl>
