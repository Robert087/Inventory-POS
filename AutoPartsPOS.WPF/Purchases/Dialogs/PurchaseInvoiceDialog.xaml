<Window x:Class="AutoPartsPOS.WPF.Purchases.Dialogs.PurchaseInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إنشاء فاتورة شراء"
        Width="980"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="إنشاء فاتورة شراء" />

        <Grid Grid.Row="1" Margin="0,18,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Column="0"
                     materialDesign:HintAssist.Hint="رقم الفاتورة"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

            <ComboBox Grid.Column="2"
                      DisplayMemberPath="NameAr"
                      ItemsSource="{Binding Suppliers}"
                      SelectedItem="{Binding SelectedSupplier}"
                      materialDesign:HintAssist.Hint="المورد"
                      Style="{StaticResource ModernComboBoxStyle}" />

            <DatePicker Grid.Column="4"
                        SelectedDate="{Binding InvoiceDate}"
                        materialDesign:HintAssist.Hint="تاريخ الفاتورة"
                        Style="{StaticResource ModernDatePickerStyle}" />

            <TextBox Grid.Row="2"
                     Grid.Column="0"
                     Grid.ColumnSpan="5"
                     Height="72"
                     AcceptsReturn="True"
                     materialDesign:HintAssist.Hint="ملاحظات"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Row="4"
                      Grid.Column="0"
                      DisplayMemberPath="NameAr"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      materialDesign:HintAssist.Hint="المنتج"
                      Style="{StaticResource ModernComboBoxStyle}" />

            <TextBox Grid.Row="4"
                     Grid.Column="2"
                     materialDesign:HintAssist.Hint="الكمية"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" />

            <StackPanel Grid.Row="4"
                        Grid.Column="4"
                        Orientation="Horizontal">
                <TextBox Width="160"
                         materialDesign:HintAssist.Hint="سعر الوحدة"
                     Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />

                <Button Margin="8,0,0,0"
                        Command="{Binding AddLineCommand}"
                        Content="إضافة"
                    Style="{StaticResource PrimaryButtonStyle}" />

                <Button Margin="8,0,0,0"
                        Command="{Binding RemoveLineCommand}"
                        Content="حذف"
                    Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Lines}"
                  SelectedItem="{Binding SelectedLine}"
                  SelectionMode="Single"
                  Style="{StaticResource ModernDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding Product.NameAr}"
                                    Header="المنتج" />
                <DataGridTextColumn Width="120"
                                    Binding="{Binding Quantity, StringFormat=N3}"
                                    Header="الكمية" />
                <DataGridTextColumn Width="120"
                                    Binding="{Binding UnitPrice, StringFormat=N2}"
                                    Header="سعر الوحدة" />
                <DataGridTextColumn Width="140"
                                    Binding="{Binding TotalPrice, StringFormat=N2}"
                                    Header="الإجمالي" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Command="{Binding SaveCommand}"
                        Content="حفظ وترحيل"
                        IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}" />
                <Button Margin="8,0,0,0"
                        Command="{Binding CancelCommand}"
                        Content="إلغاء"
                        IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>

            <StackPanel>
                <TextBlock HorizontalAlignment="Right"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="{Binding InvoiceTotal, StringFormat=الإجمالي: {0:N2}}" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
