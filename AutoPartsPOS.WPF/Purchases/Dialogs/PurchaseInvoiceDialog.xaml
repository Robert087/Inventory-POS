<Window x:Class="AutoPartsPOS.WPF.Purchases.Dialogs.PurchaseInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إنشاء فاتورة شراء"
        Width="1040"
        Height="740"
        WindowStartupLocation="CenterOwner"
        Icon="{x:Null}"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}"
        KeyboardNavigation.TabNavigation="Cycle">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="24" FontWeight="SemiBold" Text="إنشاء فاتورة شراء" />

        <Border Grid.Row="1" Margin="0,18,0,12" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ComboBox Grid.Column="0"
                          DisplayMemberPath="NameAr"
                          ItemsSource="{Binding Suppliers}"
                          SelectedItem="{Binding SelectedSupplier}"
                          materialDesign:HintAssist.Hint="المورد"
                          Style="{StaticResource ModernComboBoxStyle}"
                          TabIndex="0" />
                <DatePicker Grid.Column="2"
                            SelectedDate="{Binding InvoiceDate}"
                            materialDesign:HintAssist.Hint="التاريخ"
                            Style="{StaticResource ModernDatePickerStyle}"
                            TabIndex="1" />
                <TextBox Grid.Row="2"
                         Grid.Column="0"
                         Grid.ColumnSpan="5"
                         Height="72"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         materialDesign:HintAssist.Hint="ملاحظات"
                         Style="{StaticResource ModernTextBoxStyle}"
                         TabIndex="3"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="ProductComboBox"
                              Grid.Column="0"
                              DisplayMemberPath="NameAr"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              StaysOpenOnEdit="True"
                              materialDesign:HintAssist.Hint="ابحث عن الصنف"
                              Style="{StaticResource ModernComboBoxStyle}"
                              TabIndex="4" />
                    <TextBox x:Name="QuantityTextBox"
                             Grid.Column="1"
                             Margin="8,0,0,0"
                             materialDesign:HintAssist.Hint="الكمية"
                             Style="{StaticResource ModernTextBoxStyle}"
                             TabIndex="5"
                             DataObject.Pasting="WholeNumberTextBox_Pasting"
                             PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                             Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox x:Name="UnitPriceTextBox"
                             Grid.Column="2"
                             Margin="8,0,0,0"
                             materialDesign:HintAssist.Hint="سعر الوحدة"
                             Style="{StaticResource ModernTextBoxStyle}"
                             TabIndex="6"
                             DataObject.Pasting="WholeNumberTextBox_Pasting"
                             PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                             Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button x:Name="AddLineButton"
                            Grid.Column="3"
                            Margin="8,0,0,0"
                            Command="{Binding AddLineCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            TabIndex="7">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,6,0" Kind="Plus" />
                            <TextBlock Text="إضافة" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4"
                            Margin="8,0,0,0"
                            Command="{Binding RemoveLineCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            TabIndex="8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,6,0" Kind="DeleteOutline" />
                            <TextBlock Text="حذف" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <DataGrid x:Name="LinesGrid"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Lines}"
                          SelectedItem="{Binding SelectedLine}"
                          Style="{StaticResource ModernDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="2*" Binding="{Binding Product.NameAr}" Header="الصنف" />
                        <DataGridTextColumn Width="120" Binding="{Binding Quantity, StringFormat=F0}" Header="الكمية" />
                        <DataGridTextColumn Width="120" Binding="{Binding UnitPrice, StringFormat=F0}" Header="سعر الوحدة" />
                        <DataGridTextColumn Width="140" Binding="{Binding TotalPrice, StringFormat=F0}" Header="الإجمالي" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=LinesGrid, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد أصناف." />
                </Border>
            </Grid>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Command="{Binding SaveCommand}" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" TabIndex="9">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Margin="0,0,6,0" Kind="ContentSaveOutline" />
                        <TextBlock Text="حفظ" />
                    </StackPanel>
                </Button>
                <Button Margin="8,0,0,0" Command="{Binding CancelCommand}" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" TabIndex="10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Margin="0,0,6,0" Kind="Close" />
                        <TextBlock Text="إلغاء" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel>
                <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="SemiBold" Text="{Binding InvoiceTotal, StringFormat=الإجمالي: {0:F0}}" />
                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
