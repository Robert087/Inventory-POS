<Window x:Class="AutoPartsPOS.WPF.Purchases.Dialogs.PurchaseInvoiceDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="860"
        Height="640"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="تفاصيل فاتورة الشراء" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding Invoice.SupplierNameAr, StringFormat=المورد: {0}}" />
                    <TextBlock Text="{Binding Invoice.InvoiceDate, StringFormat=التاريخ: {0}}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold" Text="{Binding Invoice.TotalAmount, StringFormat=الإجمالي: {0:F0}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <DataGrid x:Name="PurchaseDetailsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding Invoice.Items}"
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="2*" Binding="{Binding ProductNameAr}" Header="الصنف" />
                    <DataGridTextColumn Width="120" Binding="{Binding Quantity, StringFormat=F0}" Header="الكمية" />
                    <DataGridTextColumn Width="120" Binding="{Binding UnitPrice, StringFormat=F0}" Header="سعر الوحدة" />
                    <DataGridTextColumn Width="140" Binding="{Binding TotalPrice, StringFormat=F0}" Header="الإجمالي" />
                </DataGrid.Columns>
            </DataGrid>

            <Border IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=PurchaseDetailsGrid, Path=Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد أصناف داخل هذه الفاتورة." />
            </Border>
        </Grid>

        <Button Grid.Row="2"
                Margin="0,16,0,0"
                HorizontalAlignment="Left"
                Command="{Binding CloseCommand}"
                Content="إغلاق"
                Style="{StaticResource PrimaryButtonStyle}" />
    </Grid>
</Window>
