<UserControl x:Class="AutoPartsPOS.WPF.Inventory.Views.InventoryLedgerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <DockPanel>
        <WrapPanel DockPanel.Dock="Top"
                   Margin="0,0,0,16"
                   VerticalAlignment="Center">
            <TextBox Width="320"
                     Margin="0,0,0,8"
                     materialDesign:HintAssist.Hint="بحث باسم المنتج"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Width="260"
                      Margin="8,0,0,8"
                      DisplayMemberPath="NameAr"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      materialDesign:HintAssist.Hint="تصفية حسب المنتج"
                      Style="{StaticResource ModernComboBoxStyle}" />

            <Button Margin="8,0,0,8"
                    Command="{Binding SearchCommand}"
                    Content="بحث"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </WrapPanel>

        <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Transactions}"
                  Style="{StaticResource ModernDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding ProductNameAr}"
                                    Header="المنتج" />
                <DataGridTextColumn Width="130"
                                    Binding="{Binding TransactionType}"
                                    Header="نوع الحركة" />
                <DataGridTextColumn Width="120"
                                    Binding="{Binding Quantity, StringFormat=N3}"
                                    Header="الكمية" />
                <DataGridTextColumn Width="130"
                                    Binding="{Binding BalanceAfter, StringFormat=N3}"
                                    Header="الرصيد بعد الحركة" />
                <DataGridTextColumn Width="150"
                                    Binding="{Binding ReferenceType}"
                                    Header="المرجع" />
                <DataGridTextColumn Width="140"
                                    Binding="{Binding ReferenceNumber}"
                                    Header="رقم المرجع" />
                <DataGridTextColumn Width="190"
                                    Binding="{Binding TransactionDate, StringFormat=g}"
                                    Header="التاريخ" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
