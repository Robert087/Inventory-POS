<Window x:Class="AutoPartsPOS.WPF.Sales.Dialogs.SalesInvoiceDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding Title}"
        Width="900"
        Height="660"
        WindowStartupLocation="CenterOwner"
        Icon="{x:Null}"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="تفاصيل فاتورة البيع" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding Invoice.InvoiceDate, StringFormat=التاريخ: {0}}" />
                    <TextBlock Text="{Binding Invoice.Status, StringFormat=الحالة: {0}}" />
                    <ComboBox Margin="0,10,0,0"
                              DisplayMemberPath="Value"
                              IsEnabled="{Binding CanEditPayment}"
                              ItemsSource="{Binding PaymentStatuses}"
                              SelectedValue="{Binding SelectedPaymentStatus}"
                              SelectedValuePath="Key"
                              Style="{StaticResource ModernComboBoxStyle}" />
                    <TextBox Margin="0,8,0,0"
                             DataObject.Pasting="WholeNumberTextBox_Pasting"
                             IsEnabled="{Binding IsPartiallyPaid}"
                             PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                             materialDesign:HintAssist.Hint="المبلغ المدفوع"
                             Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding RemainingAmount, StringFormat=المتبقي: {0:F0}}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock HorizontalAlignment="Right" Text="{Binding Invoice.SubtotalAmount, StringFormat=الإجمالي قبل الخصم: {0:F0}}" />
                    <TextBlock HorizontalAlignment="Right" Margin="0,6,0,0" Text="{Binding Invoice.DiscountAmount, StringFormat=الخصم: {0:F0}}" />
                    <TextBlock HorizontalAlignment="Right" Margin="0,6,0,0" FontWeight="SemiBold" Text="{Binding Invoice.NetTotalAmount, StringFormat=الصافي: {0:F0}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <DataGrid x:Name="SalesDetailsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding Invoice.Items}"
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="2*" Binding="{Binding ProductNameAr}" Header="الصنف" />
                    <DataGridTextColumn Width="120" Binding="{Binding Quantity, StringFormat=F0}" Header="الكمية" />
                    <DataGridTextColumn Width="120" Binding="{Binding UnitPrice, StringFormat=F0}" Header="سعر الوحدة" />
                    <DataGridTextColumn Width="140" Binding="{Binding TotalPrice, StringFormat=F0}" Header="الإجمالي" />
                </DataGrid.Columns>
            </DataGrid>

            <Border IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=SalesDetailsGrid, Path=Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد أصناف داخل هذه الفاتورة." />
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,16,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button Command="{Binding PreviewCommand}" Content="معاينة" Style="{StaticResource SecondaryButtonStyle}" />
            <Button Margin="8,0,0,0" Command="{Binding PrintCommand}" Content="طباعة" Style="{StaticResource PrimaryButtonStyle}" />
            <Button Margin="8,0,0,0"
                    Command="{Binding SavePaymentCommand}"
                    Content="حفظ"
                    IsEnabled="{Binding CanEditPayment}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Visibility="{Binding HasPendingPaymentChanges, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button Margin="8,0,0,0" Command="{Binding CloseCommand}" Content="إغلاق" Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
