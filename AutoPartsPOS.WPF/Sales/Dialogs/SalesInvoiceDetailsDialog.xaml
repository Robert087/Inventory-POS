<Window x:Class="AutoPartsPOS.WPF.Sales.Dialogs.SalesInvoiceDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="900"
        Height="660"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Invoice.InvoiceNumber}" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding Invoice.InvoiceDate, StringFormat=التاريخ: {0}}" />
                    <TextBlock Text="{Binding Invoice.Status, StringFormat=الحالة: {0}}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock HorizontalAlignment="Right" Text="{Binding Invoice.SubtotalAmount, StringFormat=الإجمالي قبل الخصم: {0:N2}}" />
                    <TextBlock HorizontalAlignment="Right" Margin="0,6,0,0" Text="{Binding Invoice.DiscountAmount, StringFormat=الخصم: {0:N2}}" />
                    <TextBlock HorizontalAlignment="Right" Margin="0,6,0,0" FontWeight="SemiBold" Text="{Binding Invoice.NetTotalAmount, StringFormat=الصافي: {0:N2}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <DataGrid x:Name="SalesDetailsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding Invoice.Items}"
                      Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="2*" Binding="{Binding ProductNameAr}" Header="الصنف" />
                    <DataGridTextColumn Width="120" Binding="{Binding Quantity, StringFormat=N3}" Header="الكمية" />
                    <DataGridTextColumn Width="120" Binding="{Binding UnitPrice, StringFormat=N2}" Header="سعر الوحدة" />
                    <DataGridTextColumn Width="140" Binding="{Binding TotalPrice, StringFormat=N2}" Header="الإجمالي" />
                </DataGrid.Columns>
            </DataGrid>

            <Border IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=SalesDetailsGrid, Path=Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد أصناف داخل هذه الفاتورة." />
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,16,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button Command="{Binding PreviewCommand}" Content="معاينة" Style="{StaticResource SecondaryButtonStyle}" />
            <Button Margin="8,0,0,0" Command="{Binding PrintCommand}" Content="طباعة" Style="{StaticResource PrimaryButtonStyle}" />
            <Button Margin="8,0,0,0" Command="{Binding CloseCommand}" Content="إغلاق" Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
