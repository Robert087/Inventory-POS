<Window x:Class="AutoPartsPOS.WPF.LatestPrices.Dialogs.LatestPriceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Width="560"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Icon="{x:Null}"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="{Binding DialogTitle}" />

        <ScrollViewer Grid.Row="1"
                      Margin="0,24,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ComboBox x:Name="CodeComboBox"
                          DisplayMemberPath="ProductCode"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          ItemsSource="{Binding FilteredCodeProducts}"
                          SelectionChanged="CodeComboBox_SelectionChanged"
                          StaysOpenOnEdit="True"
                          materialDesign:HintAssist.Hint="الكود"
                          Style="{StaticResource ModernComboBoxStyle}"
                          Text="{Binding CodeSearchText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <ComboBox x:Name="NameComboBox"
                          Margin="0,14,0,0"
                          DisplayMemberPath="NameAr"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          ItemsSource="{Binding FilteredNameProducts}"
                          SelectionChanged="NameComboBox_SelectionChanged"
                          StaysOpenOnEdit="True"
                          materialDesign:HintAssist.Hint="اسم الصنف"
                          Style="{StaticResource ModernComboBoxStyle}"
                          Text="{Binding NameSearchText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <Border Margin="0,16,0,0"
                        Padding="16"
                        Background="#F8FAFC"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="#64748B" Text="آخر سعر شراء مسجل" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding RegisteredLatestPriceText}" />
                    </StackPanel>
                </Border>

                <TextBox Margin="0,16,0,0"
                         materialDesign:HintAssist.Hint="أحدث سعر شراء"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding LatestPurchasePriceText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button Command="{Binding SaveCommand}" Content="حفظ" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />
            <Button Margin="8,0,0,0" Command="{Binding CancelCommand}" Content="إلغاء" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
