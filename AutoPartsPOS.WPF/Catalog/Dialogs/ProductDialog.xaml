<Window x:Class="AutoPartsPOS.WPF.Catalog.Dialogs.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Width="720"
        Height="640"
        Icon="{x:Null}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="{Binding DialogTitle}" />

        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                     materialDesign:HintAssist.Hint="كود الصنف"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

            <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                     materialDesign:HintAssist.Hint="اسم الصنف"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding NameAr, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

            <ComboBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                      DisplayMemberPath="NameAr"
                      ItemsSource="{Binding Categories}"
                      SelectedValue="{Binding CategoryId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                      SelectedValuePath="Id"
                      materialDesign:HintAssist.Hint="التصنيف"
                      Style="{StaticResource ModernComboBoxStyle}" />

            <TextBox Grid.Row="6" Grid.Column="0"
                     materialDesign:HintAssist.Hint="{Binding PurchasePriceHint}"
                     IsReadOnly="{Binding IsEditMode}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     DataObject.Pasting="WholeNumberTextBox_Pasting"
                     PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                     Text="{Binding PurchasePriceText, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox Grid.Row="6" Grid.Column="2"
                     materialDesign:HintAssist.Hint="سعر البيع"
                     Style="{StaticResource ModernTextBoxStyle}"
                     DataObject.Pasting="WholeNumberTextBox_Pasting"
                     PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                     Text="{Binding SellingPriceText, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox Grid.Row="8" Grid.Column="0"
                     materialDesign:HintAssist.Hint="المخزون الحالي"
                     Style="{StaticResource ModernTextBoxStyle}"
                     DataObject.Pasting="WholeNumberTextBox_Pasting"
                     PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                     Text="{Binding CurrentStockText, UpdateSourceTrigger=PropertyChanged}" />

            <TextBox Grid.Row="8" Grid.Column="2"
                     materialDesign:HintAssist.Hint="الحد الأدنى للمخزون"
                     Style="{StaticResource ModernTextBoxStyle}"
                     DataObject.Pasting="WholeNumberTextBox_Pasting"
                     PreviewTextInput="WholeNumberTextBox_PreviewTextInput"
                     Text="{Binding MinimumStockText, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,14,0,0">
                <TextBlock Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button Command="{Binding SaveCommand}" Content="حفظ" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />
            <Button Margin="8,0,0,0" Command="{Binding CancelCommand}" Content="إلغاء" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
