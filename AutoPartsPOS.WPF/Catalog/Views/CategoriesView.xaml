<UserControl x:Class="AutoPartsPOS.WPF.Catalog.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,16"
                    Orientation="Horizontal">
            <TextBox Width="320"
                     Margin="0,0,0,0"
                     materialDesign:HintAssist.Hint="بحث في التصنيفات"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding SearchCommand}"
                    Content="بحث"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding AddCommand}"
                    Content="إضافة"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding EditCommand}"
                    Content="تعديل"
                    Style="{StaticResource SecondaryButtonStyle}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding DeactivateCommand}"
                    Content="تعطيل"
                    Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"
                  SelectionMode="Single"
                  Style="{StaticResource ModernDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding NameAr}"
                                    Header="اسم التصنيف" />
                <DataGridTextColumn Width="3*"
                                    Binding="{Binding Description}"
                                    Header="الوصف" />
                <DataGridCheckBoxColumn Width="120"
                                        Binding="{Binding IsActive}"
                                        Header="نشط" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
