<UserControl x:Class="AutoPartsPOS.WPF.Catalog.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <DockPanel>
        <WrapPanel DockPanel.Dock="Top"
                   Margin="0,0,0,16"
                   VerticalAlignment="Center">
            <TextBox Width="320"
                     Margin="0,0,0,8"
                     materialDesign:HintAssist.Hint="بحث بالكود أو الاسم أو الباركود"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Width="220"
                      Margin="8,0,0,8"
                      DisplayMemberPath="NameAr"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource ModernComboBoxStyle}" />

            <Button Margin="8,0,0,8"
                    Command="{Binding SearchCommand}"
                    Content="بحث"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <Button Margin="8,0,0,8"
                    Command="{Binding AddCommand}"
                    Content="إضافة"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <Button Margin="8,0,0,8"
                    Command="{Binding EditCommand}"
                    Content="تعديل"
                    Style="{StaticResource SecondaryButtonStyle}" />

            <Button Margin="8,0,0,8"
                    Command="{Binding DeactivateCommand}"
                    Content="تعطيل"
                    Style="{StaticResource DangerButtonStyle}" />
        </WrapPanel>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  SelectionMode="Single"
                  Style="{StaticResource ModernDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="130"
                                    Binding="{Binding ProductCode}"
                                    Header="الكود" />
                <DataGridTextColumn Width="140"
                                    Binding="{Binding Barcode}"
                                    Header="الباركود" />
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding NameAr}"
                                    Header="اسم المنتج" />
                <DataGridTextColumn Width="160"
                                    Binding="{Binding CategoryNameAr}"
                                    Header="التصنيف" />
                <DataGridTextColumn Width="120"
                                    Binding="{Binding PurchasePrice, StringFormat=N2}"
                                    Header="سعر الشراء" />
                <DataGridTextColumn Width="120"
                                    Binding="{Binding SellingPrice, StringFormat=N2}"
                                    Header="سعر البيع" />
                <DataGridTextColumn Width="110"
                                    Binding="{Binding CurrentStock, StringFormat=N3}"
                                    Header="المخزون" />
                <DataGridTextColumn Width="110"
                                    Binding="{Binding MinimumStock, StringFormat=N3}"
                                    Header="الحد الأدنى" />
                <DataGridTemplateColumn Width="130" Header="الحالة">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="8,3"
                                    CornerRadius="4"
                                    Background="{Binding Converter={StaticResource StockStatusBrushConverter}}">
                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="White"
                                           Text="{Binding Converter={StaticResource StockStatusTextConverter}}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Width="80"
                                        Binding="{Binding IsActive}"
                                        Header="نشط" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
