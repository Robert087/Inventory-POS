<UserControl x:Class="AutoPartsPOS.WPF.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Margin="0,0,0,16"
                       HorizontalAlignment="Right"
                       Style="{StaticResource PageTitleStyle}"
                       Text="لوحة التحكم" />

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="مبيعات اليوم" />
                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                            <DatePicker Width="180"
                                        SelectedDate="{Binding DailySalesDate}"
                                        materialDesign:HintAssist.Hint="اليوم / الشهر / السنة"
                                        Style="{StaticResource ModernDatePickerStyle}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding ApplyDailySalesFilterCommand}"
                                    Content="تطبيق"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding ResetDailySalesFilterCommand}"
                                    Content="إعادة ضبط"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="مبيعات الشهر" />
                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                            <ComboBox Width="145"
                                      DisplayMemberPath="Name"
                                      ItemsSource="{Binding Months}"
                                      SelectedValue="{Binding SelectedMonth}"
                                      SelectedValuePath="Value"
                                      materialDesign:HintAssist.Hint="الشهر"
                                      Style="{StaticResource ModernComboBoxStyle}" />
                            <ComboBox Width="105"
                                      Margin="8,0,0,0"
                                      ItemsSource="{Binding Years}"
                                      SelectedItem="{Binding SelectedYear}"
                                      materialDesign:HintAssist.Hint="السنة"
                                      Style="{StaticResource ModernComboBoxStyle}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding ApplyMonthlyFilterCommand}"
                                    Content="تطبيق"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding ResetMonthlyFilterCommand}"
                                    Content="إعادة ضبط"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <UniformGrid Margin="0,0,0,16" Columns="5">
                <Border Style="{StaticResource KpiCardStyle}" Background="#ECFDF3" BorderBrush="#B7E6CF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="مبيعات اليوم" />
                            <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppSuccessBrush}" Text="{Binding TodaySales, StringFormat=F0}" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" VerticalAlignment="Top" Background="White" CornerRadius="12">
                            <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppSuccessBrush}" Kind="CashRegister" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCardStyle}" Background="#EFF6FF" BorderBrush="#C9DFFD">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="مبيعات الشهر" />
                            <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryBrush}" Text="{Binding CurrentMonthSales, StringFormat=F0}" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" VerticalAlignment="Top" Background="White" CornerRadius="12">
                            <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppPrimaryBrush}" Kind="ChartLine" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCardStyle}" Background="#F5F3FF" BorderBrush="#D9CCFF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="عدد الفواتير" />
                            <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="#5B3FD0" Text="{Binding InvoiceCount}" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" VerticalAlignment="Top" Background="White" CornerRadius="12">
                            <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5B3FD0" Kind="ReceiptTextOutline" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource KpiCardStyle}" Background="#FFF7ED" BorderBrush="#F9D7AE">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="قيمة المخزون" />
                            <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppWarningBrush}" Text="{Binding InventoryValue, StringFormat=F0}" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" VerticalAlignment="Top" Background="White" CornerRadius="12">
                            <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppWarningBrush}" Kind="Warehouse" />
                        </Border>
                    </Grid>
                </Border>

                <Border Margin="0" Style="{StaticResource KpiCardStyle}" Background="#ECFDF3" BorderBrush="#B7E6CF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="صافي الربح" />
                            <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppSuccessBrush}" Text="{Binding NetProfit, StringFormat=F0}" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="44" Height="44" VerticalAlignment="Top" Background="White" CornerRadius="12">
                            <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppSuccessBrush}" Kind="Finance" />
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <Border Width="34" Height="34" Background="#FEF3F2" CornerRadius="10">
                                <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppDangerBrush}" Kind="AlertOutline" />
                            </Border>
                            <TextBlock Margin="10,6,0,0" Style="{StaticResource SectionTitleStyle}" Text="تنبيهات المخزون" />
                        </StackPanel>
                        <Grid>
                            <DataGrid x:Name="LowStockGrid"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding LowStockProducts}"
                                      Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="140" Binding="{Binding ProductCode}" Header="الكود" />
                                    <DataGridTextColumn Width="*" Binding="{Binding ProductNameAr}" Header="الصنف" />
                                    <DataGridTextColumn Width="120" Binding="{Binding CurrentStock, StringFormat=F0}" Header="الرصيد" />
                                    <DataGridTextColumn Width="120" Binding="{Binding MinimumStock, StringFormat=F0}" Header="الحد الأدنى" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=LowStockGrid, Path=Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد تنبيهات." />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <Border Width="34" Height="34" Background="#EFF6FF" CornerRadius="10">
                                <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppPrimaryBrush}" Kind="TrendingUp" />
                            </Border>
                            <TextBlock Margin="10,6,0,0" Style="{StaticResource SectionTitleStyle}" Text="الأكثر مبيعاً" />
                        </StackPanel>
                        <Grid>
                            <DataGrid x:Name="TopSellingGrid"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding TopSellingProducts}"
                                      Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="*" Binding="{Binding ProductNameAr}" Header="الصنف" />
                                    <DataGridTextColumn Width="120" Binding="{Binding QuantitySold, StringFormat=F0}" Header="الكمية" />
                                    <DataGridTextColumn Width="140" Binding="{Binding SalesAmount, StringFormat=F0}" Header="المبيعات" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=TopSellingGrid, Path=Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد بيانات." />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <Border Width="34" Height="34" Background="#FFF7ED" CornerRadius="10">
                                <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppWarningBrush}" Kind="TimerSand" />
                            </Border>
                            <TextBlock Margin="10,6,0,0" Style="{StaticResource SectionTitleStyle}" Text="بطيئة الحركة" />
                        </StackPanel>
                        <Grid>
                            <DataGrid x:Name="SlowMovingGrid"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding SlowMovingProducts}"
                                      Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="*" Binding="{Binding ProductNameAr}" Header="الصنف" />
                                    <DataGridTextColumn Width="120" Binding="{Binding CurrentStock, StringFormat=F0}" Header="الرصيد" />
                                    <DataGridTextColumn Width="140" Binding="{Binding LastSaleDate}" Header="آخر بيع" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=SlowMovingGrid, Path=Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد بيانات." />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <Border Width="34" Height="34" Background="#ECFDF3" CornerRadius="10">
                                <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppSuccessBrush}" Kind="ReceiptTextOutline" />
                            </Border>
                            <TextBlock Margin="10,6,0,0" Style="{StaticResource SectionTitleStyle}" Text="آخر المبيعات" />
                        </StackPanel>
                        <Grid>
                            <DataGrid x:Name="RecentSalesGrid"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding RecentSales}"
                                      Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="120" Binding="{Binding InvoiceDate}" Header="التاريخ" />
                                    <DataGridTextColumn Width="120" Binding="{Binding Status}" Header="الحالة" />
                                    <DataGridTextColumn Width="140" Binding="{Binding NetTotalAmount, StringFormat=F0}" Header="الصافي" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=RecentSalesGrid, Path=Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد فواتير حديثة." />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                        <Border Width="34" Height="34" Background="#F5F3FF" CornerRadius="10">
                            <materialDesign:PackIcon HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#5B3FD0" Kind="CartArrowDown" />
                        </Border>
                        <TextBlock Margin="10,6,0,0" Style="{StaticResource SectionTitleStyle}" Text="آخر المشتريات" />
                    </StackPanel>
                    <Grid>
                        <DataGrid x:Name="RecentPurchasesGrid"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RecentPurchases}"
                                  Style="{StaticResource ModernDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="180" Binding="{Binding SupplierNameAr}" Header="المورد" />
                                <DataGridTextColumn Width="120" Binding="{Binding InvoiceDate}" Header="التاريخ" />
                                <DataGridTextColumn Width="140" Binding="{Binding TotalAmount, StringFormat=F0}" Header="الإجمالي" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=RecentPurchasesGrid, Path=Items.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد فواتير حديثة." />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ErrorBannerStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Foreground="{DynamicResource AppDangerBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
