<Window x:Class="AutoPartsPOS.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="نظام إدارة قطع وإكسسوارات السيارات"
        Width="1440"
        Height="860"
        MinWidth="1120"
        MinHeight="700"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid FlowDirection="LeftToRight">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{Binding SidebarWidth}" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" FlowDirection="RightToLeft">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="24,0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="{Binding CurrentDateTime}" />

                    <Button Grid.Column="1"
                            Command="{Binding NavigateSettingsCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="الإعدادات">
                        <materialDesign:PackIcon Kind="CogOutline" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,20,24,24">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Grid>
        </Grid>

        <Border Grid.Column="1"
                FlowDirection="RightToLeft"
                Background="{DynamicResource AppSidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="64" />
                </Grid.RowDefinitions>

                <Border Margin="16,14,16,10"
                        Background="{DynamicResource AppSidebarSoftBrush}"
                        CornerRadius="10">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Width="18"
                                                 Height="18"
                                                 VerticalAlignment="Center"
                                                 Foreground="White"
                                                 Kind="Warehouse" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="نظام المتجر"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,0,16,8">
                        <Button Command="{Binding NavigateHomeCommand}" ToolTip="لوحة التحكم">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Dashboard}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="ViewDashboardOutline" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="لوحة التحكم"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateSalesCommand}" ToolTip="المبيعات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Sales}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="PointOfSale" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="المبيعات"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigatePurchasesCommand}" ToolTip="المشتريات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Purchases}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="CartArrowDown" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="المشتريات"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateProductsCommand}" ToolTip="الأصناف">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Products}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="PackageVariantClosed" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="الأصناف"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateCategoriesCommand}" ToolTip="التصنيفات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Categories}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="ShapeOutline" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="التصنيفات"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateSuppliersCommand}" ToolTip="الموردون">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Suppliers}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="TruckOutline" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="الموردون"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateInventoryLedgerCommand}" ToolTip="المخزون">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Inventory}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="ClipboardListOutline" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="المخزون"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateReportsCommand}" ToolTip="التقارير">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Reports}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="ChartBoxOutline" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="التقارير"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateSettingsCommand}" ToolTip="الإعدادات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Settings}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="CogOutline" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="الإعدادات"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Margin="16,8,16,16"
                        Command="{Binding ToggleSidebarCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="طي القائمة">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Kind="MenuOpen" />
                        <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="طي القائمة"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
