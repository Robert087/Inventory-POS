<Window x:Class="AutoPartsPOS.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="نظام إدارة إكسسوارات السيارات"
        Width="1440"
        Height="860"
        MinWidth="1080"
        MinHeight="680"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid FlowDirection="LeftToRight">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{Binding SidebarWidth}" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" FlowDirection="RightToLeft">
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="28,0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Text="{Binding CurrentViewModel.Title, FallbackValue=لوحة التحكم}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="{Binding CurrentDateTime}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Height="44"
                            Margin="20,0"
                            VerticalAlignment="Center"
                            Background="#F8FAFC"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppMutedTextBrush}" Kind="Magnify" />
                            <TextBox Grid.Column="1"
                                     Margin="0,0,8,0"
                                     VerticalContentAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     materialDesign:HintAssist.Hint="بحث سريع في النظام..."
                                     Style="{x:Null}" />
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Command="{Binding NavigateSettingsCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="الإعدادات">
                        <materialDesign:PackIcon Kind="CogOutline" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28,24,28,28">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Grid>
        </Grid>

        <Border Grid.Column="1" FlowDirection="RightToLeft" Background="{DynamicResource AppSidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="92" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="72" />
                </Grid.RowDefinitions>

                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="44" Height="44" Background="#2563EB" CornerRadius="12">
                        <materialDesign:PackIcon Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Kind="CarCog" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Foreground="White" FontSize="16" FontWeight="Bold" Text="AutoParts ERP" />
                        <TextBlock Margin="0,3,0,0" Foreground="#94A3B8" FontSize="11" Text="إدارة متكاملة للمتجر" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="20,4,20,8" Foreground="#64748B" FontSize="10" FontWeight="Bold" Text="القائمة الرئيسية" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Command="{Binding NavigateHomeCommand}" ToolTip="لوحة التحكم"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Dashboard}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="ViewDashboardOutline" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="لوحة التحكم" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateProductsCommand}" ToolTip="الأصناف"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Products}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="PackageVariantClosed" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="الأصناف" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateCategoriesCommand}" ToolTip="التصنيفات"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Categories}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="ShapeOutline" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="التصنيفات" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateSuppliersCommand}" ToolTip="الموردين"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Suppliers}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="TruckOutline" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="الموردين" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Border Height="1" Margin="18,12" Background="#253044" />
                        <Button Command="{Binding NavigatePurchasesCommand}" ToolTip="المشتريات"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Purchases}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="CartArrowDown" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="المشتريات" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateSalesCommand}" ToolTip="المبيعات"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Sales}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="PointOfSale" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="المبيعات" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateInventoryLedgerCommand}" ToolTip="المخزون"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Inventory}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="Warehouse" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="المخزون" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateReportsCommand}" ToolTip="التقارير"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Reports}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="ChartBoxOutline" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="التقارير" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                        <Button Command="{Binding NavigateSettingsCommand}" ToolTip="الإعدادات"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=Settings}" Value="True"><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><materialDesign:PackIcon Kind="CogOutline" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="الإعدادات" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/></Grid></Button>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Margin="14" AutomationProperties.Name="طي القائمة" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource NavButtonStyle}" ToolTip="طي القائمة">
                    <materialDesign:PackIcon Kind="MenuOpen" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
