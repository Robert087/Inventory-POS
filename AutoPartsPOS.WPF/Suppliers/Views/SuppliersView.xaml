<UserControl x:Class="AutoPartsPOS.WPF.Suppliers.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,16"
                    Orientation="Horizontal">
            <TextBox Width="320"
                     materialDesign:HintAssist.Hint="بحث في الموردين"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding SearchCommand}"
                    Content="بحث"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding AddCommand}"
                    Content="إضافة"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding EditCommand}"
                    Content="تعديل"
                    Style="{StaticResource SecondaryButtonStyle}" />

            <Button Margin="8,0,0,0"
                    Command="{Binding DeactivateCommand}"
                    Content="تعطيل"
                    Style="{StaticResource DangerButtonStyle}" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Suppliers}"
                  SelectedItem="{Binding SelectedSupplier}"
                  SelectionMode="Single"
                  Style="{StaticResource ModernDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding NameAr}"
                                    Header="اسم المورد" />
                <DataGridTextColumn Width="160"
                                    Binding="{Binding Phone}"
                                    Header="الهاتف" />
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding Address}"
                                    Header="العنوان" />
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding Notes}"
                                    Header="ملاحظات" />
                <DataGridCheckBoxColumn Width="90"
                                        Binding="{Binding IsActive}"
                                        Header="نشط" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
