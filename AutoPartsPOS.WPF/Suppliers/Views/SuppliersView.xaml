<UserControl x:Class="AutoPartsPOS.WPF.Suppliers.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ToolbarCardStyle}">
            <StackPanel>
                <Grid FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding AddCommand}" Style="{StaticResource PrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Margin="0,0,6,0" Kind="Plus" />
                                <TextBlock Text="إضافة" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource PageTitleStyle}" Text="الموردون" />
                </Grid>

                <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                    <TextBox Width="320"
                             materialDesign:HintAssist.Hint="ابحث في الموردين"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="8,0,0,0" Command="{Binding SearchCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,6,0" Kind="Magnify" />
                            <TextBlock Text="بحث" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <DataGrid x:Name="SuppliersGrid"
                              IsReadOnly="True"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="220" Binding="{Binding NameAr}" Header="اسم المورد" />
                            <DataGridTextColumn Width="150" Binding="{Binding Phone}" Header="الهاتف" />
                            <DataGridTextColumn Width="*" Binding="{Binding Address}" Header="العنوان" />
                            <DataGridTemplateColumn Width="180" Header="إجراءات">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style BasedOn="{StaticResource DataGridActionCellStyle}" TargetType="DataGridCell" />
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.EditRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="تعديل"
                                                    Style="{StaticResource DataGridActionButtonStyle}" />
                                            <Button Margin="6,0,0,0"
                                                    Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="حذف"
                                                    Style="{StaticResource DataGridDangerActionButtonStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SuppliersGrid, Path=Items.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد بيانات موردين." />
                    </Border>
                </Grid>

                <Border Grid.Row="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ErrorBannerStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Foreground="{DynamicResource AppDangerBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
