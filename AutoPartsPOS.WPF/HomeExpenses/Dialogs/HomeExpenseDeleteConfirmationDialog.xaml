<Window x:Class="AutoPartsPOS.WPF.HomeExpenses.Dialogs.HomeExpenseDeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تأكيد الحذف"
        Width="480"
        Height="260"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Icon="{x:Null}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Border Margin="18"
            Padding="24"
            Background="White"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" Opacity="0.24" ShadowDepth="5" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="26"
                                             Height="26"
                                             Margin="0,0,10,0"
                                             Foreground="{DynamicResource AppDangerBrush}"
                                             Kind="AlertCircleOutline" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Text="تأكيد الحذف" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Click="CloseButton_Click"
                        Content="✕"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="0,24,0,20"
                       FontSize="16"
                       Text="هل أنت متأكد من إزالة هذا المصروف؟ سيتم الحذف نهائيًا عند حفظ التغييرات ولا يمكن التراجع عنه."
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <Button MinWidth="120"
                        Click="ConfirmButton_Click"
                        Content="نعم، حذف"
                        IsDefault="True"
                        Style="{StaticResource DangerButtonStyle}" />
                <Button MinWidth="80"
                        Margin="8,0,0,0"
                        Click="CancelButton_Click"
                        Content="لا"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
