<Window x:Class="AutoPartsPOS.WPF.HomeExpenses.Dialogs.HomeExpenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="إضافة مصاريف"
        Width="620"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Icon="{x:Null}"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="إضافة مصاريف" />

        <ScrollViewer Grid.Row="1" Margin="0,24,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DatePicker SelectedDate="{Binding ExpenseDate, ValidatesOnNotifyDataErrors=True}"
                            IsEnabled="{Binding IsDateEditable}"
                            materialDesign:HintAssist.Hint="التاريخ"
                            Style="{StaticResource ModernDatePickerStyle}" />

                <TextBox Margin="0,14,0,0"
                         materialDesign:HintAssist.Hint="البيان / الملاحظة"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding NoteText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBox Margin="0,14,0,0"
                         materialDesign:HintAssist.Hint="المبلغ"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <Button Margin="0,14,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding AddAnotherCommand}"
                        Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Margin="0,0,6,0" Kind="Plus" />
                        <TextBlock Text="إضافة مصروف آخر" />
                    </StackPanel>
                </Button>

                <Border Margin="0,16,0,0"
                        Padding="16"
                        Background="#F8FAFC"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="#64748B" Text="إجمالي المصاريف الحالي" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentTotalText}" />
                    </StackPanel>
                </Border>

                <DataGrid Margin="0,16,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding PendingItems}"
                          MaxHeight="220"
                          Style="{StaticResource ModernDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Binding="{Binding Note}" Header="البيان / الملاحظة" />
                        <DataGridTextColumn Width="140"
                                            Binding="{Binding Amount, StringFormat={}{0:F0}}"
                                            Header="المبلغ" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Margin="0,12,0,0"
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button Command="{Binding SaveCommand}" Content="حفظ" IsDefault="True" Style="{StaticResource PrimaryButtonStyle}" />
            <Button Margin="8,0,0,0" Command="{Binding CancelCommand}" Content="إلغاء" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
