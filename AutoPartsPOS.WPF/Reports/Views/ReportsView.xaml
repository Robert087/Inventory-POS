<UserControl x:Class="AutoPartsPOS.WPF.Reports.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ToolbarCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <DatePicker Width="185"
                                SelectedDate="{Binding FromDate}"
                                materialDesign:HintAssist.Hint="من تاريخ"
                                Style="{StaticResource ModernDatePickerStyle}" />
                    <DatePicker Width="185"
                                Margin="8,0,0,0"
                                SelectedDate="{Binding ToDate}"
                                materialDesign:HintAssist.Hint="إلى تاريخ"
                                Style="{StaticResource ModernDatePickerStyle}" />
                    <Button Margin="8,0,0,0"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="0,0,7,0" Kind="Refresh" />
                            <TextBlock Text="تحديث التقارير" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="مركز التقارير" />
                    <TextBlock Style="{StaticResource SectionHintStyle}" Text="تحليل الأداء المالي وحالة المخزون ضمن فترة محددة." />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
            <TabControl Background="Transparent" Style="{StaticResource MaterialDesignTabControl}">
                <TabItem Header="المبيعات">
                    <StackPanel Margin="0,16,0,0">
                        <UniformGrid Columns="4">
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" CornerRadius="10"><StackPanel><TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="عدد الفواتير" /><TextBlock Margin="0,8,0,0" FontSize="22" FontWeight="Bold" Text="{Binding SalesReport.InvoiceCount}" /></StackPanel></Border>
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" CornerRadius="10"><StackPanel><TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="إجمالي المبيعات" /><TextBlock Margin="0,8,0,0" FontSize="22" FontWeight="Bold" Text="{Binding SalesReport.TotalSales, StringFormat=F0}" /></StackPanel></Border>
                            <Border Margin="0,0,10,0" Padding="16" Background="#FFF7ED" CornerRadius="10"><StackPanel><TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="إجمالي الخصم" /><TextBlock Margin="0,8,0,0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppWarningBrush}" Text="{Binding SalesReport.TotalDiscount, StringFormat=F0}" /></StackPanel></Border>
                            <Border Padding="16" Background="#ECFDF3" CornerRadius="10"><StackPanel><TextBlock Foreground="{DynamicResource AppMutedTextBrush}" Text="صافي المبيعات" /><TextBlock Margin="0,8,0,0" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppSuccessBrush}" Text="{Binding SalesReport.NetSales, StringFormat=F0}" /></StackPanel></Border>
                        </UniformGrid>
                        <StackPanel Margin="0,22,0,0" Orientation="Horizontal">
                            <Button Command="{Binding ExportSalesPdfCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Margin="0,0,7,0" Foreground="{DynamicResource AppDangerBrush}" Kind="FilePdfBox" />
                                    <TextBlock Text="تصدير PDF" />
                                </StackPanel>
                            </Button>
                            <Button Margin="8,0,0,0" Command="{Binding ExportSalesExcelCommand}" Style="{StaticResource SecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Margin="0,0,7,0" Foreground="{DynamicResource AppSuccessBrush}" Kind="MicrosoftExcel" />
                                    <TextBlock Text="تصدير Excel" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="الأرباح">
                    <StackPanel Margin="0,16,0,0">
                        <UniformGrid Columns="3">
                            <Border Margin="0,0,10,0" Padding="20" Background="#EFF6FF" CornerRadius="10"><StackPanel><TextBlock Text="الإيرادات" /><TextBlock Margin="0,10,0,0" FontSize="24" FontWeight="Bold" Text="{Binding ProfitReport.Revenue, StringFormat=F0}" /></StackPanel></Border>
                            <Border Margin="0,0,10,0" Padding="20" Background="#FFF7ED" CornerRadius="10"><StackPanel><TextBlock Text="التكلفة" /><TextBlock Margin="0,10,0,0" FontSize="24" FontWeight="Bold" Text="{Binding ProfitReport.Cost, StringFormat=F0}" /></StackPanel></Border>
                            <Border Padding="20" Background="#ECFDF3" CornerRadius="10"><StackPanel><TextBlock Text="صافي الربح" /><TextBlock Margin="0,10,0,0" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AppSuccessBrush}" Text="{Binding ProfitReport.Profit, StringFormat=F0}" /></StackPanel></Border>
                        </UniformGrid>
                        <StackPanel Margin="0,22,0,0" Orientation="Horizontal">
                            <Button Command="{Binding ExportProfitPdfCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="تصدير PDF" />
                            <Button Margin="8,0,0,0" Command="{Binding ExportProfitExcelCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="تصدير Excel" />
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="المخزون">
                    <StackPanel Margin="0,16,0,0">
                        <UniformGrid Columns="3">
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" CornerRadius="10"><TextBlock Text="{Binding InventoryReport.TotalStockQuantity, StringFormat=إجمالي الكمية: {0:F0}}" /></Border>
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" CornerRadius="10"><TextBlock Text="{Binding InventoryReport.InventoryValue, StringFormat=قيمة المخزون: {0:F0}}" /></Border>
                            <Border Padding="16" Background="#FFF7ED" CornerRadius="10"><TextBlock Text="{Binding InventoryReport.LowStockCount, StringFormat=عناصر منخفضة: {0}}" /></Border>
                        </UniformGrid>

                        <StackPanel Margin="0,12,0,14" Orientation="Horizontal">
                            <TextBox Width="300"
                                     materialDesign:HintAssist.Hint="ابحث في قائمة المخزون"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding SearchInventoryCommand}"
                                    Content="بحث"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Command="{Binding ExportInventoryPdfCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="تصدير PDF" />
                            <Button Margin="8,0,0,0" Command="{Binding ExportInventoryExcelCommand}" Style="{StaticResource SecondaryButtonStyle}" Content="تصدير Excel" />
                        </StackPanel>

                        <Grid>
                            <DataGrid x:Name="InventoryReportGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding InventoryItems}"
                                      Style="{StaticResource ModernDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="120" Header="الكود" Binding="{Binding ProductCode}" />
                                    <DataGridTextColumn Width="*" Header="الصنف" Binding="{Binding ProductNameAr}" />
                                    <DataGridTextColumn Width="120" Header="الرصيد" Binding="{Binding CurrentStock, StringFormat=F0}" />
                                    <DataGridTextColumn Width="130" Header="متوسط التكلفة" Binding="{Binding CurrentAverageCost, StringFormat=F0}" />
                                    <DataGridTextColumn Width="140" Header="قيمة المخزون" Binding="{Binding InventoryValue, StringFormat=F0}" />
                                    <DataGridCheckBoxColumn Width="90" Header="منخفض" Binding="{Binding IsLowStock}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStateCardStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=InventoryReportGrid, Path=Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="لا توجد بيانات مخزون متاحة للتقرير." />
                            </Border>
                        </Grid>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Foreground="{DynamicResource AppSuccessBrush}" Text="{Binding SuccessMessage}" TextWrapping="Wrap" />
            <TextBlock Foreground="{DynamicResource AppDangerBrush}" Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
